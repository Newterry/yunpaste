{
  "name": "yunpaste",
  "version": "1.13.0",
  "description": "美观、安全、适合长期运行的自托管网络粘贴板与文件管理系统",
  "license": "MIT",
  "homepage": "https://github.com/Newterry/yunpaste#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Newterry/yunpaste.git"
  },
  "bugs": {
    "url": "https://github.com/Newterry/yunpaste/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"node --watch server/index.mjs\" \"vite --host 0.0.0.0\"",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "check": "tsc -b --pretty false",
    "db:status": "node server/cli.mjs database status",
    "db:encrypt": "node server/cli.mjs database encrypt",
    "test": "node --test --test-concurrency=1 --test-reporter=spec test/api/*.test.mjs test/lifecycle/*.test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3-multiple-ciphers": "12.11.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  }
}
