# 云粘贴 1.13.0
TIEYUN_IMAGE_TAG=1.13.0
TIEYUN_BIND=127.0.0.1
TIEYUN_PORT=8787

# 默认使用两个独立命名卷；也可改为 /srv/yunpaste/config 和 /srv/yunpaste/files。
TIEYUN_CONFIG_VOLUME=yunpaste-config
TIEYUN_FILES_VOLUME=yunpaste-files
# 此宿主机目录只读映射到容器 /run/secrets。
TIEYUN_SECRETS_PATH=./secrets

ADMIN_EMAIL=admin@example.com
# 首次启动必填其一。建议用 `openssl rand -base64 24` 生成，.env 权限设为 0600。
ADMIN_PASSWORD=
# 更安全的文件方式示例：/run/secrets/admin-password
ADMIN_PASSWORD_FILE=
# 仅用于隔离的本地测试；允许非邮箱账号和短密码，切勿用于公网部署。
ALLOW_INSECURE_ADMIN_CREDENTIALS=false

# 留空时会在 /config 自动生成并持久化；外部文件路径均填写容器内路径。
JWT_SECRET=
JWT_SECRET_FILE=
# 全新加密库或停机迁移后填写，例如 /run/secrets/database.key。
DATABASE_KEY_FILE=
# 可选；留空时凭据密钥保存在 /config/.storage-secret。
STORAGE_SECRET_FILE=

# 直连时保持 false；位于单层可信反向代理之后时通常设为 1。
TRUST_PROXY=false
# /files 至少保留 256 MiB；按最大文件和并发上传量上调。
MIN_FREE_BYTES=268435456

# WebDAV/SMB 的 rclone 子进程限制。
REMOTE_STORAGE_TIMEOUT_MS=120000
REMOTE_STORAGE_CONCURRENCY=8
REMOTE_STORAGE_QUEUE_LIMIT=128
